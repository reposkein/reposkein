{
  "name": "@reposkein/viz",
  "version": "0.0.0",
  "private": true,
  "description": "RepoSkein 3D constellation graph viewer (read-only SPA over committed .reposkein JSONL).",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.58.0",
    "@tanstack/react-table": "^8.20.5",
    "d3-force-3d": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@eslint/js": "^9.12.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.12.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.8.1",
    "vite": "^5.4.9",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
