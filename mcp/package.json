{
  "name": "@reposkein/mcp",
  "version": "0.1.5",
  "description": "Deterministic code-graph (GraphRAG) MCP server — give your AI agent callers/callees, change-impact, and semantic search over your repo instead of grep. 7 languages, zero-infra, git-native.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai-agents",
    "code-graph",
    "graphrag",
    "rag",
    "tree-sitter",
    "static-analysis",
    "code-intelligence",
    "code-navigation",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "developer-tools",
    "reposkein"
  ],
  "homepage": "https://github.com/reposkein/reposkein#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reposkein/reposkein.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/reposkein/reposkein/issues"
  },
  "author": "RepoSkein",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "reposkein-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "bin",
    "binary-digests.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "prepare": "npm run build && node scripts/bundle-skill.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "bench": "tsx bench/run.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "neo4j-driver": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0"
  }
}
